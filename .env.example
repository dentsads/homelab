# ──────────────────────────────────────────────
# Infrastructure Bootstrap (needed before Vaultwarden is running)
# ──────────────────────────────────────────────

# Root password for the Proxmox host (used for ISO generation)
HOST_ROOT_PASSWORD=""

# Password for the Terraform user (created by Ansible on Proxmox)
TF_USER_PASSWORD=""

# Path to your SSH Public Key (on the controller, mounted at /root/.ssh)
SSH_PUB_KEY_PATH="/root/.ssh/id_ed25519.pub"

# ──────────────────────────────────────────────
# Vaultwarden Bootstrap (for the deploy-bot user)
# ──────────────────────────────────────────────

# Admin token for Vaultwarden itself (needed to start the service)
VAULTWARDEN_ADMIN_TOKEN="<generate: openssl rand -base64 48>"

# Vaultwarden deployment user API key (generated in Vaultwarden web UI)
# Create a dedicated "Deploy Bot" user, generate API key from account settings
VAULTWARDEN_BW_CLIENTID="user.<uuid>"
VAULTWARDEN_BW_CLIENTSECRET="<api_secret>"

# Vaultwarden deployment user master password (for bw unlock)
VAULTWARDEN_BW_PASSWORD="<deploy_bot_password>"

# ──────────────────────────────────────────────
# Setup Instructions
# ──────────────────────────────────────────────
# All service secrets now live in Vaultwarden items (not in this file).
#
# Manual one-time setup:
# 1. Deploy vaultwarden:  ./run-docker.sh services deploy vaultwarden
# 2. Open https://vw.192.168.0.253.nip.io and create your admin account
# 3. Go to /admin and create Organization "Homelab"
# 4. Create Collection "Deployment" under Homelab
# 5. Create user "deploy-bot", share Deployment collection (read-only)
# 6. Generate API key for deploy-bot, add values above
# 7. Create one Login item per stack in the Deployment collection
#    with Custom Fields matching their env vars (see design doc)
# 8. Deploy everything: ./run-docker.sh all
#
# Stacks and their required custom fields:
# - proxy:      No Vaultwarden item needed (no secrets)
# - core:       No Vaultwarden item needed (no secrets)
# - homeassistant: No Vaultwarden item needed (no secrets)
# - gluetun:    GLUETUN_WIREGUARD_PRIVATE_KEY, GLUETUN_WIREGUARD_PRESHARED_KEY, GLUETUN_WIREGUARD_ADDRESSES
# - stirlingpdf: STIRLING_SECURITY_INITIALLOGIN_USERNAME, STIRLING_SECURITY_INITIALLOGIN_PASSWORD
# - adguard:    ADGUARD_USER, ADGUARD_PASSWORD
# - wireguard:  WGEASY_PASSWORD_HASH
# - opencode:   OPENCODE_SERVER_PASSWORD, OPENROUTER_API_KEY
# - openchamber: OPENCHAMBER_UI_PASSWORD, GITHUB_SSH_PRIVATE_KEY_B64, GITHUB_TOKEN